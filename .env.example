# Copy to .env and fill in. Never commit the real .env.

# Full public base URL — must match your Strava app's Authorization Callback
# Domain. Used to build the OAuth redirect URI (${APP_URL}/api/strava/callback).
# TLS is terminated by Pangolin (external reverse proxy), which forwards to the
# app on port 3000.
APP_URL=https://dashboard.example.com

# From https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Where the owner's Strava token is persisted (inside the container; mapped to a
# Docker volume). Leave as-is for the provided compose file.
STRAVA_TOKEN_FILE=/data/strava-token.json
